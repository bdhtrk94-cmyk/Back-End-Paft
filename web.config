<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    
    <!-- Handler for Node.js applications -->
    <handlers>
      <add name="httpPlatformHandler" path="*" verb="*" modules="httpPlatformHandler" resourceType="Unspecified" />
    </handlers>
    
    <!-- Node.js configuration for MonsterASP.NET -->
    <httpPlatform 
      processPath="node" 
      arguments=".\dist\main.js" 
      startupTimeLimit="120" 
      startupRetryCount="3"
      stdoutLogEnabled="true" 
      stdoutLogFile=".\logs\node"
      requestTimeout="00:04:00">
      
      <environmentVariables>
        <environmentVariable name="PORT" value="%HTTP_PLATFORM_PORT%" />
        <environmentVariable name="NODE_ENV" value="production" />
        <environmentVariable name="NODE_OPTIONS" value="--max-old-space-size=512" />
      </environmentVariables>
      
    </httpPlatform>
    
    <!-- Static files configuration -->
    <staticContent>
      <mimeMap fileExtension=".json" mimeType="application/json" />
      <mimeMap fileExtension=".js" mimeType="application/javascript" />
    </staticContent>
    
    <!-- URL Rewrite for API routes -->
    <rewrite>
      <rules>
        <rule name="NodeInspector" patternSyntax="ECMAScript" stopProcessing="true">
          <match url="^server.js\/debug[\/]?" />
        </rule>
        <rule name="StaticContent">
          <action type="Rewrite" url="public{REQUEST_URI}"/>
        </rule>
        <rule name="DynamicContent">
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="True"/>
          </conditions>
          <action type="Rewrite" url="dist/main.js"/>
        </rule>
      </rules>
    </rewrite>
    
  </system.webServer>
</configuration>